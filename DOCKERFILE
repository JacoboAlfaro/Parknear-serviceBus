# ── Etapa 1: build ──────────────────────────────────────────────────────────
FROM rust:1.85-slim AS builder

# Dependencias del sistema necesarias para sqlx (OpenSSL y libpq)
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

ARG APP_BIN=Parknear-serviceBus

# Copiar manifiestos y pre-compilar dependencias (layer cache)
COPY Cargo.toml Cargo.lock* ./
RUN mkdir src && echo "fn main() {}" > src/main.rs
RUN cargo build --release --bin ${APP_BIN}
RUN rm -f target/release/deps/parknear*

# Copiar el código fuente real y compilar el binario final
COPY src ./src
RUN cargo build --release --bin ${APP_BIN}

# ── Etapa 2: runtime ─────────────────────────────────────────────────────────
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    ca-certificates \
    libssl3 \
    libpq5 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copiar solo el binario compilado
COPY --from=builder /app/target/release/${APP_BIN} ./service-bus

# Usuario sin privilegios para mayor seguridad
RUN useradd -ms /bin/bash appuser
USER appuser

EXPOSE 3000

CMD ["./service-bus"]
